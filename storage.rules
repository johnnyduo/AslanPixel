rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatars: owner write (500 KB max), authenticated read
    match /avatars/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 500 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Pixel art exports: owner write (2 MB max), authenticated read
    match /pixel_art/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'image/png';
    }

    // Static sprite catalog: authenticated read only
    match /sprites/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Feed media: authenticated write (5 MB max)
    match /feed_media/{postId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }
    function isNotBlocked() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'BLOCK';
    }
    function validString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }

    // ── users/{uid} ───────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isAdmin());
      allow create: if isOwner(uid) && validString(request.resource.data.displayName, 1, 50);
      allow update: if isOwner(uid) && isNotBlocked() &&
        // Prevent clients from elevating their own role
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();

      // economy subcollection
      match /economy/{doc} {
        allow read: if isOwner(uid);
        allow write: if false; // Server-side only (Cloud Functions)
      }

      // agents subcollection
      match /agents/{agentId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && isNotBlocked();
      }

      // Portfolio cache — server writes, owner reads
      match /portfolio/{doc} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Insights — server writes, owner reads
      match /insights/{insightId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Order history — server writes, owner reads
      match /orderHistory/{orderId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // badges subcollection
      match /badges/{badgeId} {
        allow read: if isOwner(uid) ||
          // Public if user privacyMode is public
          get(/databases/$(database)/documents/users/$(uid)).data.privacyMode == 'public';
        allow write: if false; // Server-side only
      }

      // settings subcollection
      match /settings/{settingId} {
        allow read, write: if isOwner(uid);
      }

      // notifications subcollection
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        allow write: if false; // Create by server only
      }
    }

    // ── rooms/{uid} ───────────────────────────────────────────────────────
    match /rooms/{uid} {
      allow read: if isAuth() &&
        (isOwner(uid) ||
         get(/databases/$(database)/documents/users/$(uid)).data.privacyMode == 'public');
      allow write: if isOwner(uid) && isNotBlocked();
    }

    // ── feedPosts/{postId} ────────────────────────────────────────────────
    match /feedPosts/{postId} {
      allow read: if isAuth() && isNotBlocked();
      allow create: if isAuth() && isNotBlocked() &&
        request.resource.data.authorUid == request.auth.uid &&
        validString(request.resource.data.content, 1, 500);
      allow update: if isAuth() &&
        // Only reactions field can be updated by non-authors
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
      allow delete: if isAuth() &&
        (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // ── plazaPresence/{uid} ───────────────────────────────────────────────
    match /plazaPresence/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ── predictionEvents/{eventId} ────────────────────────────────────────
    match /predictionEvents/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin(); // Created by admin/Cloud Functions only
    }

    // ── userEntries/{uid}/entries/{entryId} ───────────────────────────────
    match /userEntries/{uid}/entries/{entryId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isNotBlocked();
      allow update: if false; // Settlement by server only
    }

    // ── pixelCanvases/{canvasId} ──────────────────────────────────────────
    match /pixelCanvases/{canvasId} {
      allow read: if isAuth() &&
        (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuth() && isNotBlocked() &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuth() &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuth() &&
        resource.data.ownerUid == request.auth.uid;
    }

    // ── agentTasks/{uid}/tasks/{taskId} ──────────────────────────────────
    match /agentTasks/{uid}/tasks/{taskId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isNotBlocked();
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ── quests/{uid}/{subcol}/{questId} ───────────────────────────────────
    match /quests/{uid}/{subcol}/{questId} {
      allow read: if isOwner(uid);
      // Client can update progress only (server generates + deletes)
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['progress', 'completed']);
      allow create, delete: if false;
    }

    // ── brokerConnections/{uid} — NEVER client-accessible ─────────────────
    match /brokerConnections/{uid} {
      allow read, write: if false;
    }

    // ── leaderboards/{type} — read-only, Cloud Functions writes ──────────
    match /leaderboards/{type} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── follows/{uid}/following/{targetUid} ──────────────────────────────
    match /follows/{uid}/following/{targetUid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) && isNotBlocked();
    }

    // ── (Legacy kept for backwards compat) ────────────────────────────────
    match /rankings/{period}/entries/{entryId} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}

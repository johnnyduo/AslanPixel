###############################
# BROKER / FINANCIAL SECRETS
###############################
# Broker API keys and tokens must NEVER be committed
broker_credentials*
*broker*.key
*broker*.pem
*api_key*
*secret_key*
encryption_key*

###############################
# SECURITY — GENERAL
###############################
# Private keys of any kind
*.rsa
*.dsa
*.ed25519
*.ecdsa
# Certificate files
*.crt
*.csr
*.cert
# SSH
id_rsa
id_dsa
id_ed25519
id_ecdsa
*.pub
~/.ssh/


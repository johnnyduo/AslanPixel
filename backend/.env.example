# AslanGuild Backend Environment Variables
# Copy to .env and fill in your values

# Gemini AI — gemini-2.0-flash-lite-preview-02-05
GEMINI_API_KEY=your_gemini_api_key_here

# Hedera Testnet — get free testnet account at portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.xxxxxx
HEDERA_PRIVATE_KEY=your_ed25519_private_key_here
HEDERA_NETWORK=testnet

# HCS Topic for audit trail (create on testnet first)
HCS_AUDIT_TOPIC_ID=0.0.5178025

# Smart Contract addresses (deploy via Remix → Hedera testnet EVM)
QUEST_RECEIPT_CONTRACT=0.0.xxxxxx
AGENT_REGISTRY_CONTRACT=0.0.xxxxxx
POLICY_MANAGER_CONTRACT=0.0.xxxxxx

# Server
PORT=3001
